{
  "name": "lazy-handler-plugin",
  "version": "0.1.0",
  "description": "Webpack/Rollup/Vite plugin that auto-extracts JSX event handlers into lazy-loaded micro-chunks. Ships zero handler JS until the user triggers an interaction.",
  "main": "src/adapters/webpack/index.js",
  "exports": {
    ".": "./src/adapters/webpack/index.js",
    "./webpack": "./src/adapters/webpack/index.js",
    "./rollup": "./src/adapters/rollup/index.js",
    "./vite": "./src/adapters/rollup/index.js",
    "./runtime": "./src/runtime/nugget-runtime.js",
    "./loader": "./src/adapters/webpack/loader.js"
  },
  "files": [
    "src/core",
    "src/adapters",
    "src/runtime",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "jest",
    "lint": "eslint src/"
  },
  "keywords": [
    "webpack",
    "rollup",
    "vite",
    "plugin",
    "code-splitting",
    "lazy-loading",
    "react",
    "jsx",
    "performance",
    "bundle-size"
  ],
  "peerDependencies": {
    "@babel/parser": ">=7.0.0",
    "@babel/traverse": ">=7.0.0",
    "@babel/generator": ">=7.0.0",
    "@babel/types": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "webpack": { "optional": true },
    "rollup": { "optional": true },
    "vite": { "optional": true }
  },
  "devDependencies": {
    "webpack": "^5.88.0",
    "@babel/parser": "^7.23.0",
    "@babel/traverse": "^7.23.0",
    "@babel/generator": "^7.23.0",
    "@babel/types": "^7.23.0",
    "jest": "^29.0.0"
  },
  "license": "MIT"
}
